# Python tooling noise
__pycache__/
.pytest_cache/
.ruff_cache/
*.pyc
.venv/

# Secrets / local env
.env
*.env

# Symphony runtime state
podium.db
podium.db-shm
podium.db-wal
podium.db.predelete-bak-*
podium.db.*.bak-*
podium.db.pre*.bak
runs/
.symphony-runs/

# Operator working dirs (gitignored but local-only)
plans/
Plans/
test-results/

# Tool previews / local agent scaffolding
.bindings.yml.preview
.WORKFLOW.md.preview
.pi-lens/
.rpiv/
artifacts/

# Archival / backups
*.archive
worktrees/

# Harness runtime sentinel (empty local marker that lifts self-disarm guard)
.claude/.harness-unlock

# /graphify outputs — knowledge-graph build artifacts, regenerated per run.
# Inputs are tracked files; outputs are local-only state.
graphify-out/

# /youtube skill pulls — transcripts + yt-dlp metadata are regenerable from the URL.
# Only the curated `transcript-extract.md` and `web-research.md` per slug are kept.
youtube/*/raw/

# Wiki maintenance counter — runtime state incremented on every wiki write.
# Lives on disk for the gate to read; not part of the wiki content surface.
wiki/.gate-state.json
