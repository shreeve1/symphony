#!/usr/bin/env bash
set -euo pipefail

UNIT_NAME="${1:-unknown-unit}"
CHAT_ID="${TELEGRAM_CHAT_ID:-${TELEGRAM_HOME_CHANNEL:-}}"

if [[ -z "${TELEGRAM_BOT_TOKEN:-}" || -z "${CHAT_ID}" ]]; then
  logger -t telegram-alert "skipped ${UNIT_NAME}: missing TELEGRAM_BOT_TOKEN or chat id"
  exit 0
fi

HOSTNAME_VALUE="$(hostname -f 2>/dev/null || hostname)"
STATE="$(systemctl show "${UNIT_NAME}" --property=ActiveState,SubState,Result --no-pager 2>/dev/null | tr '\n' ' ')"
MESSAGE="SYSTEMD FAILURE
Host: ${HOSTNAME_VALUE}
Unit: ${UNIT_NAME}
State: ${STATE}"

export TELEGRAM_BOT_TOKEN CHAT_ID MESSAGE
python3 - <<'PY'
import os
import urllib.parse
import urllib.request

url = f"https://api.telegram.org/bot{os.environ['TELEGRAM_BOT_TOKEN']}/sendMessage"
payload = urllib.parse.urlencode({
    "chat_id": os.environ["CHAT_ID"],
    "text": os.environ["MESSAGE"],
}).encode("utf-8")
request = urllib.request.Request(url, data=payload, method="POST")
with urllib.request.urlopen(request, timeout=10) as response:
    response.read()
PY

logger -t telegram-alert "sent failure alert for ${UNIT_NAME}"
